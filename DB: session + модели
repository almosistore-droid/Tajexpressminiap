# app/services/parcel_service.py
from app.db.session import SessionLocal
from app.db.models import Parcel, User, StatusEnum
from app.services.pricing import calculate_price

def process_scan(track_code: str, operator_role: str):
    db = SessionLocal()

    parcel = db.query(Parcel).filter_by(track_code=track_code).first()

    if not parcel:
        parcel = Parcel(track_code=track_code, status=StatusEnum.IN_TRANSIT)
        db.add(parcel)
        db.commit()
        return "created", None, parcel

    # логика по ролям
    if operator_role == "OPERATOR_TJ":
        parcel.status = StatusEnum.ARRIVED_TJ
        parcel.weight = parcel.weight or 1
        parcel.price = calculate_price(parcel.weight)

    db.commit()

    user = None
    if parcel.user_id:
        user = db.query(User).get(parcel.user_id)

    return "updated", user, parcel


def bulk_scan(track_codes: list, role: str):
    results = []
    for code in track_codes:
        results.append(process_scan(code, role))
    return results


def bind_track_to_user(track_code: str, telegram_id: str):
    db = SessionLocal()

    user = db.query(User).filter_by(telegram_id=telegram_id).first()
    if not user:
        user = User(telegram_id=telegram_id)
        db.add(user)
        db.commit()

    parcel = db.query(Parcel).filter_by(track_code=track_code).first()
    if not parcel:
        parcel = Parcel(track_code=track_code, user_id=user.id)
        db.add(parcel)
    else:
        parcel.user_id = user.id

    db.commit()
    return parcel
# app/bot.py
from aiogram import Bot, Dispatcher, types
import os
from app.services.parcel_service import process_scan, bulk_scan, bind_track_to_user

bot = Bot(token=os.getenv("BOT_TOKEN"))
dp = Dispatcher()

@dp.message(commands=["start"])
async def start(message: types.Message):
    await message.answer("Вы зарегистрированы")

@dp.message(commands=["add"])
async def add_track(message: types.Message):
    track = message.text.split(" ")[1]
    bind_track_to_user(track, str(message.from_user.id))
    await message.answer(f"Трек привязан: {track}")

@dp.message(commands=["scan_bulk"])
async def scan_bulk(message: types.Message):
    tracks = message.text.replace("/scan_bulk", "").strip().split()
    res = bulk_scan(tracks, "OPERATOR_TJ")
    await message.answer(f"Обработано: {len(res)}")

@dp.message()
async def scan(message: types.Message):
    track = message.text.strip()
    result = process_scan(track, "OPERATOR_TJ")

    if result[0] == "updated" and result[1]:
        await bot.send_message(
            result[1].telegram_id,
            f"📦 {track} прибыл\n💰 {result[2].price}$"
        )

await message.answer("OK")
